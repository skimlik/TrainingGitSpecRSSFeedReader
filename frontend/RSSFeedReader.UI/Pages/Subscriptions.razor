@page "/"
@using RSSFeedReader.UI.Models
@inject HttpClient Http

<PageTitle>Subscriptions</PageTitle>

<h1>Subscriptions</h1>

<div class="mb-3">
    <div class="input-group">
        <input type="text" class="form-control" placeholder="Feed URL" @bind="newUrl" />
        <button class="btn btn-primary" @onclick="AddSubscription">Add</button>
    </div>
</div>

@if (subscriptions == null)
{
    <p><em>Loading...</em></p>
}
else if (!subscriptions.Any())
{
    <p>No subscriptions yet.</p>
}
else
{
    <ul class="list-group">
        @foreach (var sub in subscriptions)
        {
            <li class="list-group-item">@sub.Url</li>
        }
    </ul>
}

@code {
    private string newUrl = string.Empty;
    private List<Subscription>? subscriptions;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubscriptions();
    }

    private async Task LoadSubscriptions()
    {
        subscriptions = await Http.GetFromJsonAsync<List<Subscription>>("subscriptions");
    }

    private async Task AddSubscription()
    {
        if (!string.IsNullOrWhiteSpace(newUrl))
        {
            var newSub = new Subscription { Url = newUrl };
            var response = await Http.PostAsJsonAsync("subscriptions", newSub);
            if (response.IsSuccessStatusCode)
            {
                newUrl = string.Empty;
                await LoadSubscriptions();
            }
        }
    }
}
